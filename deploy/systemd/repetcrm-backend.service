[Unit]
Description=RepetCRM Backend (FastAPI)
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/repetcrm/backend
EnvironmentFile=/opt/repetcrm/backend/.env
ExecStart=/opt/repetcrm/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
