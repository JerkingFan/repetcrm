# Copy to deploy/loadtest/.env.loadtest and adjust

# API base (on server usually localhost)
BASE_URL=http://127.0.0.1:8000

# Target load: 50 tutors × 10 students (matches audit scenario)
TUTORS=50
STUDENTS=10
LESSONS=20
LOADTEST_PASSWORD=LoadTest123!

# Scenario timing (tutor-daily)
RAMP_UP=30s
STEADY=2m
RAMP_DOWN=20s
THINK_TIME=1

# k6 docker image
K6_IMAGE=grafana/k6:0.54.0
