SECRET_KEY=change-me-in-production
# SQLite (простой деплой) или PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/repetcrm
DATABASE_URL=sqlite:///./data/repetcrm.db

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-7b-instruct
OPENROUTER_TIMEOUT_SEC=120
OPENROUTER_MAX_TOKENS=4096

# Локальная Qwen (опционально, если без OpenRouter)
LOCAL_ENABLE_TRANSFORMERS=false
LOCAL_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
LOCAL_MODEL_DIR=./models/Qwen2.5-1.5B-Instruct
LOCAL_MODEL_MAX_TOKENS=1200
LOCAL_TRANSFORMERS_TIMEOUT_SEC=900
LOCAL_MODEL_PRELOAD=false

AI_USE_OLLAMA=false
AI_ALLOW_TEMPLATE_FALLBACK=true
# smart — быстро и без мусора от Llama; openrouter — нейросеть; auto = openrouter + fallback
HOMEWORK_AI_PROVIDER=smart
LATEX_ONLINE_COMPILE=true
LATEX_ONLINE_URL=https://latexonline.cc/compile
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_LOCALHOST_REGEX=true
MEDIA_DIR=./media

# Boards / Whiteboard safety
BOARD_ASSET_MAX_BYTES=10485760
BOARD_PERSIST_DEBOUNCE_SEC=6

# Brute-force protection (Redis when REDIS_URL set; in-memory fallback)
AUTH_LOGIN_MAX_FAILURES=8
AUTH_LOGIN_WINDOW_SEC=60
AUTH_LOGIN_FAIL_DELAY_SEC=0.5
AUTH_REGISTER_MAX_PER_IP=5
AUTH_REGISTER_WINDOW_SEC=3600

# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# JWT: short access + refresh cookie
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false

# PostgreSQL connection pool (ignored for SQLite)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Dashboard cache TTL (seconds)
DASHBOARD_CACHE_TTL_SEC=30

# Background jobs (in-memory MVP)
JOB_TTL_SEC=600
JOB_RETENTION_SEC=3600
AI_GLOBAL_CONCURRENCY=8
OPENROUTER_MAX_RETRIES=3
