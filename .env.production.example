# Скопируйте в .env.production на сервере и заполните значения
# cp .env.production.example .env.production

# === Публичные URL (как видит браузер пользователя) ===
# API через nginx на том же домене (рекомендуется):
NEXT_PUBLIC_API_URL=https://example.com/api

FRONTEND_PORT=3000
BACKEND_PORT=8000

# === Безопасность ===
SECRET_KEY=сгенерируйте-длинную-случайную-строку-минимум-32-символа

# === База данных ===
# Вариант A: SQLite (проще, один сервер)
DATABASE_URL=sqlite:///./data/repetcrm.db

# Вариант B: PostgreSQL (рекомендуется для продакшена)
# docker compose -f docker-compose.prod.yml --env-file .env.production --profile postgres up -d --build
# POSTGRES_USER=repetcrm
# POSTGRES_PASSWORD=strong-password-here   # обязательно при --profile postgres
# POSTGRES_DB=repetcrm
# DATABASE_URL=postgresql+psycopg2://repetcrm:strong-password-here@db:5432/repetcrm

# === CORS (URL фронтенда через запятую) ===
CORS_ORIGINS=https://example.com,https://www.example.com
# Для repetcrm.ru: https://repetcrm.ru,https://www.repetcrm.ru
CORS_ALLOW_LOCALHOST_REGEX=false

# === OpenRouter (генерация ДЗ) ===
HOMEWORK_AI_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=qwen/qwen-2.5-7b-instruct
OPENROUTER_TIMEOUT_SEC=120
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_SITE_URL=https://example.com
OPENROUTER_APP_NAME=RepetCRM

# === Локальные модели на сервере — обычно выключены ===
LOCAL_ENABLE_TRANSFORMERS=false
AI_USE_OLLAMA=false
AI_ALLOW_TEMPLATE_FALLBACK=true

# === PDF (LaTeX в облаке) ===
LATEX_ONLINE_COMPILE=true
LATEX_ONLINE_URL=https://latexonline.cc/compile

MEDIA_DIR=./media
